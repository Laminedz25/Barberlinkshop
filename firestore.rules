rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isNotSuspended() {
      return isAuthenticated() && getUserData().get('suspended', false) == false;
    }

    function isBarber() {
      return isAuthenticated() && getUserData().role == 'barber';
    }

    // ─── USERS Collection ───────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read their OWN profile
      // Admins can read all profiles
      // CRITICAL: Users cannot read OTHER users' private data
      allow read: if isOwner(userId) || isAdmin();

      // Creation: Only the user themselves, and they CANNOT set role='admin'
      allow create: if isOwner(userId)
                    && request.resource.data.role != 'admin'
                    && request.resource.data.keys().hasAll(['email', 'role', 'created_at']);

      // Update: Owner can update their own profile, but CANNOT change role or suspended status
      allow update: if (isOwner(userId)
                       && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'suspended', 'id']))
                    || isAdmin();

      // Delete: Admin only
      allow delete: if isAdmin();
    }

    // ─── BARBERS/SALONS Collection ──────────────────────────
    match /barbers/{barberId} {
      // Public discovery — but only visible/active profiles
      allow read: if true;

      // Barber creates their own profile; they cannot claim someone else's user_id
      allow create: if isAuthenticated()
                    && isNotSuspended()
                    && request.resource.data.user_id == request.auth.uid;

      // Barber updates their own profile but cannot change user_id or verified status
      allow update: if isAuthenticated()
                    && isNotSuspended()
                    && (resource.data.user_id == request.auth.uid || isAdmin())
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['user_id', 'verified', 'subscription_tier']);

      // Only admin can delete barber profiles
      allow delete: if isAdmin();
    }

    // ─── BOOKINGS Collection ─────────────────────────────────
    match /bookings/{bookingId} {
      // CRITICAL: Only customer or their barber can read a booking — no cross-access
      allow read: if isAuthenticated()
                  && (resource.data.customer_id == request.auth.uid
                      || resource.data.barber_user_id == request.auth.uid
                      || isAdmin());

      // Only authenticated, non-suspended users can book FOR THEMSELVES
      allow create: if isAuthenticated()
                    && isNotSuspended()
                    && request.resource.data.customer_id == request.auth.uid
                    && request.resource.data.keys().hasAll(['customer_id', 'barber_user_id', 'service_id', 'date', 'status']);

      // Barber can update status; customer can only cancel their own booking
      allow update: if isAuthenticated()
                    && isNotSuspended()
                    && (resource.data.barber_user_id == request.auth.uid
                        || (resource.data.customer_id == request.auth.uid
                            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
                        || isAdmin());

      allow delete: if isAdmin();
    }

    // ─── PAYMENTS Collection ─────────────────────────────────
    match /payments/{paymentId} {
      // Users can only see their own payments
      allow read: if isAuthenticated()
                  && (resource.data.user_id == request.auth.uid || isAdmin());

      // Only system (via Admin SDK) or admin can write payments
      allow write: if isAdmin();
    }

    // ─── ANALYTICS Collection ───────────────────────────────
    match /analytics/{docId} {
      allow read: if isAdmin();
      // Authenticated users can log their own events
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ─── SYSTEM Collection ──────────────────────────────────
    match /system/{document=**} {
      // Public system config can be read by all
      allow read: if resource.data.get('public', false) == true || isAdmin();
      allow write: if isAdmin();
    }

    // ─── CHATS Collection ───────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuthenticated()
                  && (resource.data.participants.hasAny([request.auth.uid]) || isAdmin());

      allow create: if isAuthenticated()
                    && isNotSuspended()
                    && request.resource.data.participants.hasAny([request.auth.uid]);

      allow update: if isAuthenticated()
                    && resource.data.participants.hasAny([request.auth.uid]);

      allow delete: if isAdmin();
    }

    // ─── MESSAGES Subcollection ─────────────────────────────
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated()
                  && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);

      allow create: if isAuthenticated()
                    && isNotSuspended()
                    && request.resource.data.sender_id == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // ─── REVIEWS Collection ─────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;

      // Only post reviews for your own completed bookings
      allow create: if isAuthenticated()
                    && isNotSuspended()
                    && request.resource.data.customer_id == request.auth.uid;

      allow update: if isOwner(resource.data.customer_id) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── WALLETS Collection (Financial Engine) ──────────────
    match /wallets/{walletId} {
      // Barbers can only see their own wallet balance and history
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isAdmin());
      // Only system (Admin SDK) can write to wallets
      allow write: if isAdmin();
    }

    // ─── REFERRALS Collection ──────────────────────────────
    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (resource.data.referrer_id == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isNotSuspended();
      allow update, delete: if isAdmin();
    }

    // ─── NOTIFICATIONS Collection ───────────────────────────
    // ─── MESSAGES (Top-level Global) ─────────────────────────
    match /messages/{messageId} {
      allow read: if isAuthenticated()
                  && (resource.data.participants.hasAny([request.auth.uid]) || isAdmin());

      allow create: if isAuthenticated()
                    && isNotSuspended()
                    && request.resource.data.participants.hasAny([request.auth.uid])
                    && request.resource.data.sender_id == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    // ─── SYSTEM / INVESTOR_METRICS ─────────────────────────
    match /system/investor_metrics {
      allow read, write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }
  }
}
